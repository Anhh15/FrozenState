			<Item class="Script" referent="RBX64B6021D1721490D872567399E131532">
				<Properties>
					<ProtectedString name="Source"><![CDATA[local tool = script.Parent
local handle = tool:WaitForChild("Handle")

local defaultWalkSpeed = 16
local freezeDuration = 3

local hitTargets = {}
local isSwinging = false

tool.Activated:Connect(function()
    if isSwinging then return end
    isSwinging = true
    
    -- Tool swing animation is handled by Roblox defaults since it has a Handle
    task.wait(0.5) -- Swing duration
    isSwinging = false
end)

handle.Touched:Connect(function(hit)
    if not isSwinging then return end
    
    local character = hit.Parent
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local hrp = character:FindFirstChild("HumanoidRootPart")
    
    if humanoid and hrp and humanoid.Health > 0 then
        -- Prevent hitting the user
        if character == tool.Parent then return end
        
        if not hitTargets[character] then
            hitTargets[character] = true
            
            -- Freeze logic
            humanoid.WalkSpeed = 0
            hrp.Anchored = true
            
            -- Create IceBlock
            local IceBlock = workspace.IceBlock:Clone()
            
            -- Weld IceBlock to HumanoidRootPart
            IceBlock.CFrame = hrp.CFrame
            local weld = Instance.new("WeldConstraint")
            weld.Part0 = hrp
            weld.Part1 = IceBlock
            weld.Parent = IceBlock
            
            IceBlock.Parent = character
            
            -- Unfreeze logic
            task.delay(freezeDuration, function()
                if humanoid and humanoid.Parent then
                    humanoid.WalkSpeed = defaultWalkSpeed
                end
                if hrp and hrp.Parent then
                    hrp.Anchored = false
                end
                if IceBlock then
                    IceBlock:Destroy()
                end
                hitTargets[character] = nil
            end)
        end
    end
end)
]]></ProtectedString>
